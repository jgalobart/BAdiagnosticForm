# MS_CLIENT_ID=your_azure_app_client_id
# MS_CLIENT_SECRET=your_azure_app_client_secret
# MS_EXCEL_DRIVE_ID=your_onedrive_or_sharepoint_drive_id
# MS_EXCEL_ITEM_ID=your_excel_file_item_id
# MS_EXCEL_WORKSHEET=Sheet1
